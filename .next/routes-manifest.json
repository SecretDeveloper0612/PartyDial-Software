      "routeKeys": {},
      "namedRegex": "^/admin/settings(?:/)?$"
    },
    {
      "page": "/admin/vendors",
      "regex": "^/admin/vendors(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/vendors(?:/)?$"
    },
    {
      "page": "/mobile-app",
      "regex": "^/mobile\\-app(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/mobile\\-app(?:/)?$"
    },
    {
      "page": "/post-requirement",
      "regex": "^/post\\-requirement(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/post\\-requirement(?:/)?$"
    },
    {
      "page": "/register",
      "regex": "^/register(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/register(?:/)?$"
    },
    {
      "page": "/search",
      "regex": "^/search(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/search(?:/)?$"
    },
    {
      "page": "/vendor",
      "regex": "^/vendor(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/vendor(?:/)?$"
    },
    {
      "page": "/vendor/analytics",
      "regex": "^/vendor/analytics(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/vendor/analytics(?:/)?$"
    },
    {
      "page": "/vendor/leads",
      "regex": "^/vendor/leads(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/vendor/leads(?:/)?$"
    },
    {
      "page": "/vendor/messages",
      "regex": "^/vendor/messages(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/vendor/messages(?:/)?$"
    },
    {
      "page": "/vendor/quote",
