{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/vendor/layout,_N_T_/vendor/analytics/layout,_N_T_/vendor/analytics/page,_N_T_/vendor/analytics"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/vendor/analytics/__PAGE__",
    "/vendor/analytics",
    "/vendor",
    "/_index",
    "/_head"
  ]
}