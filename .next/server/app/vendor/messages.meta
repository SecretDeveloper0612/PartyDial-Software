{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/vendor/layout,_N_T_/vendor/messages/layout,_N_T_/vendor/messages/page,_N_T_/vendor/messages"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/vendor/messages/__PAGE__",
    "/vendor/messages",
    "/vendor",
    "/_index",
    "/_head"
  ]
}